<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
  <id>chat.rsstoat.RsStoat</id>
  <launchable type="desktop-id">chat.rsstoat.RsStoat.desktop</launchable>
  <name>rsStoat</name>
  <developer id="lol.hisoka.rsstoat">
    <name>hisoka</name>
  </developer>
  <summary>Tauri v2 desktop client for Stoat chat</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>
  <description>
    <p>rsStoat is a Tauri v2 port of the Stoat desktop client. Send messages, share
      images, mention users, and join voice channels — all from a lightweight
      native application.</p>
  </description>
  <releases>
    <release date="2026-06-23" version="1.4.0">
      <description>
        <p>Match upstream release. Added screen sharing via native picker, notification permission auto-grant, and Windows taskbar badge overlay.</p>
      </description>
    </release>
    <release date="2026-06-17" version="1.3.0">
      <description>
        <p>Initial Tauri v2 port (rsStoat).</p>
      </description>
    </release>
  </releases>
  <url type="bugtracker">https://github.com/hisoka-root/rsstoat/issues</url>
  <url type="homepage">https://stoat.chat</url>
  <url type="vcs-browser">https://github.com/hisoka-root/rsstoat</url>
  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-info">intense</content_attribute>
    <content_attribute id="social-audio">intense</content_attribute>
    <content_attribute id="social-contacts">intense</content_attribute>
  </content_rating>
  <requires>
    <display_length compare="ge">940</display_length>
    <internet>always</internet>
  </requires>
  <supports>
    <control>keyboard</control>
    <control>pointing</control>
  </supports>
</component>
